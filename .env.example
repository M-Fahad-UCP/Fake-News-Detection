# =========================================================================
# Frontend (frontend/.env)
# =========================================================================

# SQLite during dev; swap for Postgres URL in production.
DATABASE_URL="file:./prisma/dev.db"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# URL of the FastAPI ML service.
# In production this is your Render service URL, e.g. https://fnd-ml.onrender.com
ML_API_URL="http://127.0.0.1:8000"

# =========================================================================
# Backend ML (backend-ml/.env, optional)
# =========================================================================

# Comma-separated list of allowed origins for CORS.
# ALLOWED_ORIGINS="http://localhost:3000,https://your-app.vercel.app"

# Port the FastAPI service listens on (defaults to 8000).
# PORT=8000
